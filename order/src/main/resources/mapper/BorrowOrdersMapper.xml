<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aynu.order.mapper.BorrowOrdersMapper">

    <resultMap type="com.aynu.order.domain.po.BorrowOrdersPO" id="BorrowOrdersMap">
        <result property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="itemId" column="item_id"/>
        <result property="borrowerId" column="borrower_id"/>
        <result property="lenderId" column="lender_id"/>
        <result property="title" column="title"/>
        <result property="price" column="price"/>
        <result property="billingType" column="billing_type"/>
        <result property="deposit" column="deposit"/>
        <result property="borrowDays" column="borrow_days"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="status" column="status"/>
        <result property="purpose" column="purpose"/>
        <result property="confirmTime" column="confirm_time"/>
        <result property="payTime" column="pay_time"/>
        <result property="payTradeNo" column="pay_trade_no"/>
        <result property="borrowTime" column="borrow_time"/>
        <result property="expectReturnTime" column="expect_return_time"/>
        <result property="actualReturnTime" column="actual_return_time"/>
        <result property="refundTime" column="refund_time"/>
        <result property="cancelReason" column="cancel_reason"/>
        <result property="version" column="version"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="getTotalAmount" resultType="java.math.BigDecimal">
        select sum(total_amount)
        from borrow_orders
        where status in (3, 4, 5)
    </select>

    <select id="getTodayAmount" resultType="java.math.BigDecimal">
        select sum(total_amount)
        from borrow_orders
        where status in (3, 4, 5)
          and borrow_time between #{todayStartTime} and #{todayEndTime}
    </select>


    <select id="getBorrowOrdersCount" resultType="com.aynu.order.domain.dto.BorrowOrdersCountDTO">
        select status as statusId, count(id) as count
        from borrow_orders
        group by status
    </select>

</mapper>
